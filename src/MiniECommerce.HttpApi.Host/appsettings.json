{
  "App": {
    "SelfUrl": "https://localhost:44360",
    "DisablePII": false,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Server=(LocalDb)\\MSSQLLocalDB;Database=MiniECommerce;Trusted_Connection=True;TrustServerCertificate=true"
  },
  "AuthServer": {
    "Authority": "https://localhost:44360",
    "RequireHttpsMetadata": true,
    "SwaggerClientId": "MiniECommerce_Swagger",
    "CertificatePassPhrase": "4a69c7f5-8966-4bef-a191-99eb5009f015"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "ufFQbdJ1Q1VqDZOX"
  }}